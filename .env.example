# ─── Environment Variables ────────────────────────────────────────────────────
# Copy this file to the appropriate location and fill in values.
#
#   API vars  → apps/api/.dev.vars          (local dev, never commit)
#   Admin vars → apps/admin/.env.local      (local dev, never commit)

# ─── App ─────────────────────────────────────────────────────────────────────
# Runtime environment: local | staging | production
ENVIRONMENT=local

# Comma-separated list of allowed CORS origins (admin :3000, merchant :3001, checkout :3003).
# With ENVIRONMENT=local the API also unions common localhost:* dev origins (see apps/api/src/index.ts).
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3003

# ─── Auth ────────────────────────────────────────────────────────────────────
# Must be at least 32 characters; use a random string in production
JWT_SECRET=your-jwt-secret-min-32-chars-change-in-production

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8787/v1/auth/google/callback

# ─── Email (Cloudflare Email Service) ────────────────────────────────────────
# Cloudflare account ID — see https://dash.cloudflare.com → right-side "Account ID"
CF_ACCOUNT_ID=your-cloudflare-account-id
# Scoped API token with the "Send Email" permission
# (deployed envs: `wrangler secret put CF_API_TOKEN [--env staging|production]`)
CF_API_TOKEN=your-cloudflare-api-token
# "From" address shown in outgoing emails (must be a verified sending domain)
EMAIL_FROM=noreply@yourdomain.com

# ─── URLs ────────────────────────────────────────────────────────────────────
# Frontend URL — used by the API for OAuth redirects and email links
WEB_URL=http://localhost:3000

# API base URL — consumed by the admin frontend
NEXT_PUBLIC_API_URL=http://localhost:8787

# Public base URL for R2-hosted assets (profile pictures, uploads)
ASSETS_URL=https://assets.yourdomain.com

# =============================================================================
# Local deploy environment — template for .env.{production,staging}
# =============================================================================
#
# Copy this file to ONE OR MORE of:
#   .env.production
#   .env.staging
#
# Fill in the real values for that env. Both files are gitignored.
# `scripts/render-wrangler.mjs <app> <env>` reads .env.<env> at deploy time,
# substitutes ${VAR} into apps/<app>/wrangler.jsonc, runs the deploy, then
# restores the template.
#
# Authentication:
#   - `wrangler login` once, OR
#   - export CLOUDFLARE_API_TOKEN=… in your shell (not in this file)
#
# Wrangler secrets (CF_API_TOKEN, JWT_SECRET, ENCRYPTION_KEY,
# GOOGLE_CLIENT_SECRET) are set via `wrangler secret put <NAME> [--env <env>]`
# — they live on the deployed worker, never in this file.
# =============================================================================


# --- Cloudflare account ---
# Account ID (UUID from CF dashboard URL or `wrangler whoami`)
CF_ACCOUNT_ID=

# workers.dev subdomain (the part before .workers.dev in your Worker URLs).
# Used by apps/<frontend>/scripts/deploy-env.mjs to build default
# NEXT_PUBLIC_API_URL when not set explicitly.
CF_WORKERS_SUBDOMAIN=


# --- API resources for this env ---
# D1 database name and ID. Use separate resources per env, for example
# production: bropay-db, staging: bropay-db-staging.
API_D1_DATABASE_NAME=

# Create with: wrangler d1 create bropay-db-staging
API_D1_DATABASE_ID=

# KV namespace ID for rate-limit storage.
# Create with: wrangler kv namespace create RATE_LIMIT_KV [--env <env>]
API_RATE_LIMIT_KV_ID=

# API R2 buckets. Use separate bucket names per env.
API_ASSETS_BUCKET_NAME=
API_SLIPS_BUCKET_NAME=

# Route domain for the api worker (e.g. api.example.com). wrangler auto-creates
# the Workers Custom Domain on first deploy if the zone is in the CF account.
API_ROUTE_DOMAIN=

# Route domain for the admin frontend
ADMIN_ROUTE_DOMAIN=

# Route domain for the merchant frontend
MERCHANT_ROUTE_DOMAIN=

# Route domain for the checkout frontend
CHECKOUT_ROUTE_DOMAIN=


# --- API runtime vars (rendered into wrangler.jsonc `vars` block) ---
EMAIL_FROM=noreply@example.com
ASSETS_URL=https://assets.example.com
ALLOWED_ORIGINS=https://admin.example.com,https://merchant.example.com,https://checkout.example.com
WEB_URL=https://admin.example.com
GOOGLE_CLIENT_ID=
GOOGLE_REDIRECT_URI=https://api.example.com/v1/auth/google/callback


# --- Frontend cache KV namespace IDs ---
# Use separate physical KV namespaces per app and env.
# Create with names such as bropay-admin-CACHE-staging.
ADMIN_KV_ID=
MERCHANT_KV_ID=
RESELLER_KV_ID=


# --- Checkout build-time vars (baked into bundle) ---
# Used by apps/checkout/wrangler.jsonc env.<env>.vars.NEXT_PUBLIC_API_URL
CHECKOUT_API_URL=https://api.example.com


# --- Other frontends ---
# vinext bakes NEXT_PUBLIC_API_URL at build time. The renderer sets it
# from this var before spawning `vinext deploy`. Same value for admin /
# merchant / reseller (they all talk to the same api worker per env).
NEXT_PUBLIC_API_URL=https://api.example.com
